// O indice unico (userId, fingerprint) da migration inicial foi substituido
// por um indice unico PARCIAL (WHERE source = 'import'), criado via SQL raw na
// migration `imports-partial-unique-fingerprint` (change 008). Motivo: a dedup
// por fingerprint so faz sentido para transacoes IMPORTADAS -- duas
// transacoes MANUAIS identicas (mesma data/valor/descricao) sao um cenario
// legitimo (ex.: duas compras iguais no mesmo dia) e nao podem ser bloqueadas.
model Transaction {
  id          String    @id @default(uuid())
  date        DateTime
  description String
  type        String
  amount      Decimal   @db.Decimal(14, 2)
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id])
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  source      String    @default("manual")
  importId    String?
  fingerprint String
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([userId, date])
  @@index([userId, fingerprint])
  @@map("transactions")
}
